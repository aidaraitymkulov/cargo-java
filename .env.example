# Database
DB_NAME=ades_db
DB_USERNAME=ades_user
DB_PASSWORD=changeme_strong_password

# JWT (минимум 32 символа каждый)
JWT_ACCESS_SECRET=change_this_to_random_32plus_chars_secret
JWT_REFRESH_SECRET=change_this_to_another_random_32plus_chars

# Superadmin (создаётся при первом запуске)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme_strong_password
ADMIN_EMAIL=admin@example.com

# Mail (для отправки кодов подтверждения)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# CORS (фронтенд, через запятую не поддерживается — один origin)
CORS_ALLOWED_ORIGINS=https://greenchicken.kg

# SmartPoint
SMARTPOINT_API_TOKEN=
SMARTPOINT_WEBHOOK_SECRET=