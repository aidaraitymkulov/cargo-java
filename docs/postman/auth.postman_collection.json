{
  "info": {
    "name": "CargoApp — Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "branchId",
      "value": ""
    },
    {
      "key": "resetToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Mobile",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"john_doe\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"aitymkulovich@gmail.com\",\n  \"phone\": \"+996700000001\",\n  \"dateOfBirth\": \"1995-06-15\",\n  \"password\": \"secret123\",\n  \"branchId\": \"{{branchId}}\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', res.accessToken);",
                  "pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"john_doe\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', res.accessToken);",
                  "pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Resend Confirmation",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/resend?login=john_doe",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend"],
              "query": [{ "key": "login", "value": "john_doe" }]
            },
            "header": []
          }
        },
        {
          "name": "Confirm Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/confirm",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"john_doe\",\n  \"code\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password — Request Code",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password — Verify Code",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set('resetToken', res.resetToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password/verify",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"code\": \"1234\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password — Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password/reset",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"newSecret123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin (Web)",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Client-Type",
                "value": "web"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              {
                "key": "X-Client-Type",
                "value": "web"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {
                "key": "X-Client-Type",
                "value": "web"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            }
          }
        }
      ]
    },
    {
      "name": "Protected (пример)",
      "item": [
        {
          "name": "Get Me (Mobile)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        },
        {
          "name": "Get Me (Web)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [
              {
                "key": "X-Client-Type",
                "value": "web"
              }
            ]
          }
        }
      ]
    }
  ]
}
