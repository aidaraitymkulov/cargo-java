{
  "info": {
    "name": "CargoApp — Branches",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Mobile",
      "item": [
        {
          "name": "GET /branches",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/branches",
            "description": "Список всех филиалов. Без авторизации. Возвращает latitude, longitude, photoUrl, phone, workingHours для отображения на карте."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /admin/branches",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/branches",
            "description": "Список всех филиалов. SUPER_ADMIN."
          }
        },
        {
          "name": "GET /admin/branches/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/branches/{{branchId}}",
            "description": "Получить один филиал по ID. SUPER_ADMIN."
          }
        },
        {
          "name": "POST /admin/branches",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/admin/branches",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "address", "value": "г. Бишкек, ул. Манаса 40", "type": "text" },
                { "key": "personalCodePrefix", "value": "AN", "type": "text" },
                { "key": "latitude", "value": "42.8746", "type": "text" },
                { "key": "longitude", "value": "74.5698", "type": "text" },
                { "key": "phone", "value": "+996312000000", "type": "text" },
                { "key": "workingHours", "value": "Пн-Пт 09:00-18:00", "type": "text" },
                { "key": "photo", "type": "file", "src": "" }
              ]
            },
            "description": "Создать новый филиал. SUPER_ADMIN. Все поля кроме address и personalCodePrefix — опциональны."
          }
        },
        {
          "name": "PATCH /admin/branches/:id",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/branches/{{branchId}}",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "address", "value": "г. Бишкек, ул. Чуй 123", "type": "text" },
                { "key": "latitude", "value": "42.8746", "type": "text" },
                { "key": "longitude", "value": "74.5698", "type": "text" },
                { "key": "phone", "value": "+996312000000", "type": "text" },
                { "key": "workingHours", "value": "Пн-Пт 09:00-18:00", "type": "text" },
                { "key": "photo", "type": "file", "src": "" }
              ]
            },
            "description": "Обновить филиал. SUPER_ADMIN. Все поля опциональны. Если photo передан — заменяет старый."
          }
        }
      ]
    }
  ]
}