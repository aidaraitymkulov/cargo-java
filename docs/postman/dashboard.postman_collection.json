{
  "info": {
    "name": "CargoApp — Dashboard",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminCookie", "value": "" },
    { "key": "branchId", "value": "" }
  ],
  "item": [
    {
      "name": "Summary (cards)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard/summary",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "dashboard", "summary"],
          "query": [
            { "key": "branchId", "value": "{{branchId}}", "disabled": true }
          ]
        },
        "description": "Карточки дашборда. revenueThisWeek только для SUPER_ADMIN."
      }
    },
    {
      "name": "Chart — New Users",
      "request": {
        "method": "GET",
        "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard/charts/users?from=2026-05-01&to=2026-05-24",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "dashboard", "charts", "users"],
          "query": [
            { "key": "from", "value": "2026-05-01" },
            { "key": "to", "value": "2026-05-24" },
            { "key": "branchId", "value": "{{branchId}}", "disabled": true }
          ]
        }
      }
    },
    {
      "name": "Chart — Products DELIVERED",
      "request": {
        "method": "GET",
        "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard/charts/products/delivered?from=2026-05-01&to=2026-05-24",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "dashboard", "charts", "products", "delivered"],
          "query": [
            { "key": "from", "value": "2026-05-01" },
            { "key": "to", "value": "2026-05-24" },
            { "key": "branchId", "value": "{{branchId}}", "disabled": true }
          ]
        }
      }
    }
  ]
}
