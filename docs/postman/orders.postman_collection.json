{
  "info": {
    "name": "CargoApp — Orders",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Mobile",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "status", "value": "PENDING_PICKUP", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/orders?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "GET /admin/orders/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/orders/stats",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders", "stats"],
              "query": [
                { "key": "branchId", "value": "{{branchId}}", "disabled": true }
              ]
            },
            "description": "Кол-во заказов PENDING_PICKUP. MANAGER — свой филиал. SUPER_ADMIN без branchId — всё приложение."
          }
        },
        {
          "name": "GET /admin/orders/revenue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/orders/revenue",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders", "revenue"],
              "query": [
                { "key": "branchId", "value": "{{branchId}}", "disabled": true },
                { "key": "year", "value": "2026", "disabled": true },
                { "key": "month", "value": "3", "disabled": true }
              ]
            },
            "description": "Выручка за месяц по доставленным заказам. По умолчанию — текущий месяц. MANAGER — свой филиал."
          }
        }
      ]
    }
  ]
}
