{
  "info": {
    "name": "CargoApp — Products",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Mobile",
      "item": [
        {
          "name": "Get My Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products/my?page=1&pageSize=20",
              "host": ["{{baseUrl}}"],
              "path": ["products", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "20" },
                { "key": "status", "value": "IN_CHINA", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Get Product History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}", "history"]
            }
          }
        },
        {
          "name": "Get Items Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/items/summary",
              "host": ["{{baseUrl}}"],
              "path": ["items", "summary"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get User Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/products?page=1&pageSize=50",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "50" }
              ]
            }
          }
        },
        {
          "name": "GET /admin/products/stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Cookie", "value": "{{adminCookie}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/products/stats",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products", "stats"],
              "query": [
                { "key": "branchId", "value": "{{branchId}}", "disabled": true }
              ]
            },
            "description": "Кол-во товаров ON_THE_WAY. MANAGER — свой филиал. SUPER_ADMIN без branchId — всё приложение."
          }
        }
      ]
    }
  ]
}
